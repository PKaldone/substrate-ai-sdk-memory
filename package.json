{
  "name": "substrate-memory-ai-sdk",
  "version": "1.0.0",
  "description": "SUBSTRATE cognitive memory provider for the Vercel AI SDK",
  "main": "dist/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./src/index.ts"
    }
  },
  "files": [
    "dist/",
    "src/",
    "README.md"
  ],
  "scripts": {

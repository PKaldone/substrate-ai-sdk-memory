  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "ai": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
